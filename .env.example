# Instance config — every value here can also live in data/config-local.json (gitignored),
# which wins over env. A fresh clone boots with NONE of these set (blank-canvas mode).

# Identity
DASHBOARD_USER_NAME=            # greeting name ("Good morning, <name>"); empty = no name
DASHBOARD_OWNER=                # default Owner written on task rows
DASHBOARD_LOCALE=en-GB

# Google (storage + calendar) — share the Sheet & calendar with the service account email
DASHBOARD_KEY_FILE=             # path to a service-account key JSON; absent = Application Default Credentials
DASHBOARD_SHEET_ID=             # the task-hub spreadsheet id
DASHBOARD_PREFS_SHEET_ID=       # the news-preferences spreadsheet id (optional; news config surfaces need it)
STABLE_SHEET_ID=                # agent-stable data spreadsheet (optional; falls back to DASHBOARD_SHEET_ID)
DASHBOARD_CALENDAR_ID=          # default Google calendar id; empty = calendar shows its setup hint

# Auth (cloud deployments)
DASHBOARD_PASSWORD=             # simple password gate
GOOGLE_OAUTH_CLIENT_ID=         # set both to enable "Sign in with Google" instead
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_EMAIL=                  # the one Google account allowed through OAuth
SESSION_SECRET=                 # cookie-signing secret (required if exposed beyond localhost)

# Optional integrations
JOURNAL_VAULT=                  # path to an Obsidian-style vault with a "Daily Journal" folder
XAI_API_KEY=                    # X/Twitter "Following" section via grok
JINA_API_KEY=                   # fallback article fetcher
GCP_PROJECT=                    # Vertex (Gemini) provider
CLAUDE_BIN=                     # claude CLI path override (agent features)
